menu "Audio Studio"

config AUDIO_STUDIO
  bool "Audio Studio build"
  default y

choice TARGET_PLATFORM
  prompt "Audio target chip/platform profile"
  default TARGET_PLATFORM_A2

config TARGET_PLATFORM_A2
  bool "A2"

config TARGET_PLATFORM_SIMULATOR
  bool "Simulator"

endchoice

config GUI_BACKEND
  bool "Build GUI backend"
  default y

config BUILD_TESTS
  bool "Build unit tests"
  default y

config DRIVER_INTERFACE_TESTS
  bool "Build driver interface tests"
  default n
  depends on BUILD_TESTS

config SERVER_FRAMEWORK_TESTS
  bool "Build server framework tests"
  default n
  depends on BUILD_TESTS && FRAMEWORK_COMMON

config SERVER
  bool "Build as_server"
  default n

config RPC
  bool "Build server RPC helpers"
  default n
  depends on SERVER && FRAMEWORK_COMMON

config CLI
  bool "Build CLI tools"
  default n
  depends on SERVER

config FRAMEWORK_COMMON
  bool "Build common framework library"
  default n

config FRAMEWORK_SESSION
  bool "Build session framework library"
  default n
  depends on FRAMEWORK_COMMON

config FRAMEWORK_CONTROL
  bool "Build control framework library"
  default n
  depends on FRAMEWORK_COMMON

config FRAMEWORK_AUDIO
  bool "Build audio framework library"
  default n
  depends on FRAMEWORK_COMMON

config FRAMEWORK_LOG
  bool "Build log framework library"
  default n
  depends on FRAMEWORK_COMMON

config FRAMEWORK_DUMP
  bool "Build dump framework library"
  default n
  depends on FRAMEWORK_COMMON

config FRAMEWORK_PLUGIN
  bool "Build plugin framework library"
  default n
  depends on FRAMEWORK_COMMON

config FRAMEWORK_TRANSPORT
  bool "Build transport framework library"
  default n
  depends on FRAMEWORK_COMMON

config DRIVERS_CORE
  bool "Build driver manager core"
  default n
  depends on SERVER && FRAMEWORK_COMMON

config DRIVER_OS
  bool "Build OS driver interface"
  default n
  depends on DRIVERS_CORE

config DRIVER_OS_LINUX_HOST
  bool "Build Linux host OS driver implementation"
  default n
  depends on DRIVER_OS

config DRIVER_SOCKET
  bool "Build socket driver interface"
  default n
  depends on DRIVERS_CORE

config DRIVER_SOCKET_LINUX_HOST
  bool "Build Linux host socket driver implementation"
  default n
  depends on DRIVER_SOCKET

config DRIVER_FILESYSTEM
  bool "Build filesystem driver interface"
  default n
  depends on DRIVERS_CORE

config DRIVER_FILESYSTEM_LINUX_HOST
  bool "Build Linux host filesystem driver implementation"
  default n
  depends on DRIVER_FILESYSTEM

config DRIVER_PIPE
  bool "Build pipe driver interface"
  default n
  depends on DRIVERS_CORE

config DRIVER_PIPE_LINUX_HOST
  bool "Build Linux host pipe driver implementation"
  default n
  depends on DRIVER_PIPE

config DRIVER_DYNLIB
  bool "Build dynamic library driver interface"
  default n
  depends on DRIVERS_CORE

config DRIVER_DYNLIB_LINUX_HOST
  bool "Build Linux host dynamic library driver implementation"
  default n
  depends on DRIVER_DYNLIB

config DRIVER_TRANSPORT
  bool "Build transport driver interface"
  default n
  depends on DRIVERS_CORE

config DRIVER_TRANSPORT_LINUX_HOST
  bool "Build Linux host transport driver implementation"
  default n
  depends on DRIVER_TRANSPORT

config DRIVER_AUDIO
  bool "Build audio driver interface"
  default n
  depends on DRIVERS_CORE

config DRIVER_AUDIO_LINUX_HOST
  bool "Build Linux host audio driver implementation"
  default n
  depends on DRIVER_AUDIO

config DRIVER_CONTROL
  bool "Build control driver interface"
  default n
  depends on DRIVERS_CORE

config DRIVER_CONTROL_LINUX_HOST
  bool "Build Linux host control driver implementation"
  default n
  depends on DRIVER_CONTROL

config DRIVER_LOG
  bool "Build log driver interface"
  default n
  depends on DRIVERS_CORE

config DRIVER_LOG_LINUX_HOST
  bool "Build Linux host log driver implementation"
  default n
  depends on DRIVER_LOG

config DRIVER_DUMP
  bool "Build dump driver interface"
  default n
  depends on DRIVERS_CORE

config DRIVER_DUMP_LINUX_HOST
  bool "Build Linux host dump driver implementation"
  default n
  depends on DRIVER_DUMP

config PLATFORM_CORE
  bool "Build platform registry core"
  default n
  depends on SERVER && FRAMEWORK_COMMON

config PLATFORM_A2
  bool "Build A2 platform implementation"
  default y if TARGET_PLATFORM_A2 && PLATFORM_CORE
  depends on TARGET_PLATFORM_A2 && PLATFORM_CORE

config DRIVER_DUMMY
  bool "Build host-alone dummy driver"
  default n
  depends on SERVER

endmenu
