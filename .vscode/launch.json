{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Debug Server",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/audio_studio_gui_server",
      "args": [
        "${workspaceFolder}",
        "${input:serverPort}",
        "--as-server",
        "${workspaceFolder}/out/linux/simulator/rpc_socket/Debug/as_server",
        "--alsatplg",
        "${workspaceFolder}/third_party/alsatplg/bin/alsatplg",
        "--as-server-rpc-mode",
        "socket",
        "--as-server-host",
        "127.0.0.1",
        "--as-server-port",
        "${input:asServerPort}",
        "--validation-python",
        "python3",
        "--validation-script",
        "${workspaceFolder}/../application/rv32qemu/sof-build-test.py",
        "--validation-as-log",
        "${workspaceFolder}/out/linux/simulator/rpc_socket/Debug/as_log",
        "--validation-trace-ldc",
        "${workspaceFolder}/../application/rv32qemu/build/sof.ldc",
        "--validation-ready-timeout-ms",
        "120000",
        "--runtime-as-server-host",
        "127.0.0.1",
        "--runtime-as-server-port",
        "${input:asServerPort}",
        "--audio-driver-factory",
        "simulator"
      ],
      "cwd": "${workspaceFolder}",
      "terminal": "integrated",
      "preLaunchTask": "cmake: build debug"
    },
    {
      "name": "Backend: Profile",
      "type": "node-terminal",
      "request": "launch",
      "command": "AUDIO_STUDIO_PROFILE_SECONDS=${input:profileSeconds} \"${workspaceFolder}/scripts/profile_backend.sh\" ${input:serverPort}",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "cmake: build profile"
    },
    {
      "name": "Frontend: Debug Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://127.0.0.1:${input:serverPort}",
      "webRoot": "${workspaceFolder}/GUI/frontend",
      "sourceMaps": false,
      "runtimeArgs": [
        "--remote-debugging-port=9222",
        "--auto-open-devtools-for-tabs",
        "--user-data-dir=${workspaceFolder}/.vscode/chrome-debug-profile"
      ],
      "preLaunchTask": "wait: backend"
    },
    {
      "name": "Frontend: Attach Chrome",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/GUI/frontend",
      "sourceMaps": false
    },
    {
      "name": "Frontend: Profile Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://127.0.0.1:${input:serverPort}",
      "webRoot": "${workspaceFolder}/GUI/frontend",
      "sourceMaps": false,
      "runtimeArgs": [
        "--auto-open-devtools-for-tabs",
        "--enable-precise-memory-info",
        "--user-data-dir=${workspaceFolder}/.vscode/chrome-profile"
      ],
      "preLaunchTask": "wait: backend"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Debug",
      "configurations": [
        "Backend: Debug Server",
        "Frontend: Debug Chrome"
      ],
      "stopAll": true
    },
    {
      "name": "Full Stack: Profile",
      "configurations": [
        "Backend: Profile",
        "Frontend: Profile Chrome"
      ],
      "stopAll": true
    }
  ],
  "inputs": [
    {
      "id": "serverPort",
      "type": "promptString",
      "description": "Audio Studio server port",
      "default": "8080"
    },
    {
      "id": "profileSeconds",
      "type": "promptString",
      "description": "Backend sampling duration in seconds",
      "default": "30"
    },
    {
      "id": "asServerPort",
      "type": "promptString",
      "description": "Audio Studio as_server RPC port",
      "default": "9900"
    }
  ]
}
