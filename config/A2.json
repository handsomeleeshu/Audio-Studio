{
  "meta": {
    "schema_id": "com.vsi.a2.audio_config",
    "schema_version": "1.1.0",
    "compiler_compat": { "min": "1.5.0", "max": "1.x" },
    "firmware_abi": {
      "vass_runtime": "3.4",
      "module_abi_min": 2,
      "module_abi_max": 3
    },
    "build": {
      "config_name": "A2_Automotive_Full_Feature_Example",
      "created_utc": "2026-01-20T00:00:00Z"
    }
  },

  "naming": {
    "kcontrol": {
      "auto_create": true,
      "name_template_instance": "{inst_name} {param_name}",
      "name_template_pipeline": "{pipe_name} {node_name} {param_name}",
      "category_field": "category"
    }
  },

  "hardware_hints": {
    "cores": {
      "core0": { "role": "vass_master" },
      "core1": { "role": "vass_worker" },
      "core2": { "role": "vass_worker" },
      "core3": { "role": "service_core", "services": ["asrc", "anc_filter"] }
    },
    "dsp_frequency_mhz": {
      "unit": "MHz",
      "default": 600,
      "description": "DSP main frequency options used by Audio Studio target configuration.",
      "by_target": {
        "HiFi5s": [400, 500, 600, 800],
        "ZSP": [300, 400, 500, 600],
        "Native Mock": [300, 400, 500, 600, 800]
      }
    },
    "audio_ios": {
      "tdm_ports": [
        { "id": "TDM0", "use": "7870_audio", "dir": "bidir", "max_ch": 16, "rates": [48000, 96000] },
        { "id": "TDM1", "use": "7870_audio", "dir": "bidir", "max_ch": 16, "rates": [48000] },
        { "id": "TDM2", "use": "7870_audio", "dir": "bidir", "max_ch": 16, "rates": [48000] },
        { "id": "TDM3", "use": "7870_audio", "dir": "bidir", "max_ch": 16, "rates": [48000] },

        { "id": "TDM4", "use": "a2b_external", "dir": "bidir", "max_ch": 32, "rates": [48000] },
        { "id": "TDM5", "use": "a2b_external", "dir": "bidir", "max_ch": 32, "rates": [48000] },

        { "id": "TDM6", "use": "radio_dab", "dir": "in", "max_ch": 2, "rates": [48000] },
        { "id": "TDM7", "use": "radio_am", "dir": "in", "max_ch": 2, "rates": [48000] },
        { "id": "TDM8", "use": "radio_fm", "dir": "in", "max_ch": 2, "rates": [48000] },

        { "id": "TDM9", "use": "reserved", "dir": "bidir", "max_ch": 16, "rates": [48000] },
        { "id": "TDM10", "use": "reserved", "dir": "bidir", "max_ch": 16, "rates": [48000] },
        { "id": "TDM11", "use": "reserved", "dir": "bidir", "max_ch": 16, "rates": [48000] }
      ],
      "i2s_fusa": [
        { "id": "I2S_FS0", "use": "fusa_audio_out", "dir": "out", "max_ch": 2, "rates": [48000] },
        { "id": "I2S_FS1", "use": "fusa_audio_out", "dir": "out", "max_ch": 2, "rates": [48000] }
      ],
      "pcie": [{ "id": "PCIE0", "use": "alt_audio_or_dump", "dir": "bidir" }]
    }
  },

  "module_types": [
    {
      "type_id": "graph.copier",
      "category": "graph/basic",
      "abi_version": 2,
      "io": { "in_ports": [{ "name": "in", "max_ch": 32 }], "out_ports": [{ "name": "out", "max_ch": 32 }] },
      "runtime_params": [
        {
          "param_id": "enable",
          "param_name": "Switch",
          "value_type": "bool",
          "default": true,
          "tlv": { "type": 12288, "length_bytes": 1 },
          "kcontrol": { "kind": "switch", "scope": "instance", "category": "Graph" },
          "apply": { "mode": "next_frame" }
        }
      ]
    },

    {
      "type_id": "mix.mixer",
      "category": "graph/basic",
      "abi_version": 2,
      "io": { "in_ports": [{ "name": "in0", "max_ch": 16 }, { "name": "in1", "max_ch": 16 }, { "name": "in2", "max_ch": 16 }, { "name": "in3", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "static_schema": { "preset_ref": true, "fields": [{ "key": "num_inputs", "type": "uint8", "default": 2 }, { "key": "saturation", "type": "bool", "default": true }] },
      "runtime_params": [
        {
          "param_id": "gain_db",
          "param_name": "Gain",
          "value_type": "int16",
          "unit": "dB",
          "range": { "min": -60, "max": 12, "step": 1 },
          "default": 0,
          "tlv": { "type": 12289, "length_bytes": 2, "encoding": { "qfmt": "q8.8" } },
          "kcontrol": { "kind": "value", "scope": "instance", "category": "Mix", "tlv_scale": { "min": -60, "max": 12, "step": 1 } },
          "apply": { "mode": "next_frame" }
        }
      ]
    },

    {
      "type_id": "route.mux",
      "category": "graph/routing",
      "abi_version": 2,
      "io": { "in_ports": [{ "name": "a", "max_ch": 16 }, { "name": "b", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "runtime_params": [
        {
          "param_id": "sel",
          "param_name": "Select",
          "value_type": "enum",
          "enum": ["A", "B"],
          "default": "A",
          "tlv": { "type": 12304, "length_bytes": 1 },
          "kcontrol": { "kind": "enum", "scope": "pipeline", "category": "Routing" },
          "apply": { "mode": "immediate", "requires_graph_update": true }
        }
      ]
    },

    {
      "type_id": "route.selector",
      "category": "graph/routing",
      "abi_version": 2,
      "io": { "in_ports": [{ "name": "in0", "max_ch": 16 }, { "name": "in1", "max_ch": 16 }, { "name": "in2", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "runtime_params": [
        {
          "param_id": "index",
          "param_name": "Select",
          "value_type": "uint8",
          "range": { "min": 0, "max": 2, "step": 1 },
          "default": 0,
          "tlv": { "type": 12305, "length_bytes": 1 },
          "kcontrol": { "kind": "enum", "scope": "pipeline", "category": "Routing", "enum_labels": ["Path0", "Path1", "Path2"] },
          "apply": { "mode": "immediate", "requires_graph_update": true }
        }
      ]
    },

    {
      "type_id": "gain.volume",
      "category": "playback/basic",
      "abi_version": 2,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "runtime_params": [
        {
          "param_id": "vol_db",
          "param_name": "Volume",
          "value_type": "int16",
          "unit": "dB",
          "range": { "min": -90, "max": 12, "step": 1 },
          "default": 0,
          "tlv": { "type": 16384, "length_bytes": 2, "encoding": { "qfmt": "q8.8" } },
          "kcontrol": { "kind": "value", "scope": "instance", "category": "Playback", "tlv_scale": { "min": -90, "max": 12, "step": 1 } },
          "apply": { "mode": "next_frame" }
        },
        {
          "param_id": "mute",
          "param_name": "Mute",
          "value_type": "bool",
          "default": false,
          "tlv": { "type": 16385, "length_bytes": 1 },
          "kcontrol": { "kind": "switch", "scope": "instance", "category": "Playback" },
          "apply": { "mode": "immediate" }
        }
      ]
    },

    {
      "type_id": "filter.dcblock",
      "category": "common/filter",
      "abi_version": 2,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "runtime_params": [
        {
          "param_id": "enable",
          "param_name": "Switch",
          "value_type": "bool",
          "default": true,
          "tlv": { "type": 16640, "length_bytes": 1 },
          "kcontrol": { "kind": "switch", "scope": "instance", "category": "Common" },
          "apply": { "mode": "next_frame" }
        }
      ]
    },

    {
      "type_id": "eq.iir",
      "category": "playback/eq",
      "abi_version": 3,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "static_schema": { "preset_ref": true, "fields": [{ "key": "num_biquads", "type": "uint16", "default": 10 }, { "key": "layout", "type": "enum", "enum": ["per_ch", "shared"], "default": "per_ch" }] },
      "runtime_params": [
        {
          "param_id": "enable",
          "param_name": "EQ Switch",
          "value_type": "bool",
          "default": true,
          "tlv": { "type": 16896, "length_bytes": 1 },
          "kcontrol": { "kind": "switch", "scope": "instance", "category": "Playback EQ" },
          "apply": { "mode": "next_frame" }
        },
        {
          "param_id": "coef_blob",
          "param_name": "EQ Coeff",
          "value_type": "bytes",
          "bytes": { "max_len": 4096 },
          "tlv": { "type": 16897, "length_bytes": "var" },
          "kcontrol": { "kind": "bytes", "scope": "instance", "category": "Playback EQ" },
          "apply": { "mode": "safe_point", "requires_graph_quiesce": true }
        }
      ]
    },

    {
      "type_id": "eq.fir",
      "category": "playback/eq",
      "abi_version": 3,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "static_schema": { "preset_ref": true, "fields": [{ "key": "taps", "type": "uint16", "default": 256 }, { "key": "block", "type": "uint16", "default": 64 }] },
      "runtime_params": [
        {
          "param_id": "coef_blob",
          "param_name": "FIR Coeff",
          "value_type": "bytes",
          "bytes": { "max_len": 8192 },
          "tlv": { "type": 17152, "length_bytes": "var" },
          "kcontrol": { "kind": "bytes", "scope": "instance", "category": "Playback EQ" },
          "apply": { "mode": "safe_point", "requires_graph_quiesce": true }
        }
      ]
    },

    {
      "type_id": "dyn.drc",
      "category": "playback/dynamics",
      "abi_version": 3,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "static_schema": { "preset_ref": true, "fields": [{ "key": "knee", "type": "enum", "enum": ["soft", "hard"], "default": "soft" }] },
      "runtime_params": [
        {
          "param_id": "enable",
          "param_name": "DRC Switch",
          "value_type": "bool",
          "default": true,
          "tlv": { "type": 17408, "length_bytes": 1 },
          "kcontrol": { "kind": "switch", "scope": "instance", "category": "Dynamics" },
          "apply": { "mode": "next_frame" }
        },
        {
          "param_id": "threshold_db",
          "param_name": "Threshold",
          "value_type": "int16",
          "unit": "dB",
          "range": { "min": -60, "max": 0, "step": 1 },
          "default": -18,
          "tlv": { "type": 17409, "length_bytes": 2, "encoding": { "qfmt": "q8.8" } },
          "kcontrol": { "kind": "value", "scope": "instance", "category": "Dynamics", "tlv_scale": { "min": -60, "max": 0, "step": 1 } },
          "apply": { "mode": "next_frame" }
        }
      ]
    },

    {
      "type_id": "dyn.multiband_drc",
      "category": "playback/dynamics",
      "abi_version": 3,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "static_schema": { "preset_ref": true, "fields": [{ "key": "bands", "type": "uint8", "default": 3 }] },
      "runtime_params": [
        {
          "param_id": "enable",
          "param_name": "MBDRC Switch",
          "value_type": "bool",
          "default": false,
          "tlv": { "type": 17664, "length_bytes": 1 },
          "kcontrol": { "kind": "switch", "scope": "instance", "category": "Dynamics" },
          "apply": { "mode": "next_frame" }
        },
        {
          "param_id": "band_cfg",
          "param_name": "Band Config",
          "value_type": "bytes",
          "bytes": { "max_len": 2048 },
          "tlv": { "type": 17665, "length_bytes": "var" },
          "kcontrol": { "kind": "bytes", "scope": "instance", "category": "Dynamics" },
          "apply": { "mode": "safe_point", "requires_graph_quiesce": true }
        }
      ]
    },

    {
      "type_id": "filter.crossover",
      "category": "playback/filter",
      "abi_version": 2,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "low", "max_ch": 16 }, { "name": "high", "max_ch": 16 }] },
      "runtime_params": [
        {
          "param_id": "freq_hz",
          "param_name": "Xover Freq",
          "value_type": "uint16",
          "unit": "Hz",
          "range": { "min": 50, "max": 5000, "step": 10 },
          "default": 120,
          "tlv": { "type": 17920, "length_bytes": 2 },
          "kcontrol": { "kind": "value", "scope": "instance", "category": "Filter" },
          "apply": { "mode": "safe_point" }
        }
      ]
    },

    {
      "type_id": "mix.up_down_mixer",
      "category": "playback/spatial",
      "abi_version": 2,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "runtime_params": [
        {
          "param_id": "mode",
          "param_name": "UpDownMix Mode",
          "value_type": "enum",
          "enum": ["stereo_to_5_1", "stereo_to_7_1", "5_1_to_stereo", "7_1_to_stereo", "passthrough"],
          "default": "passthrough",
          "tlv": { "type": 18176, "length_bytes": 1 },
          "kcontrol": { "kind": "enum", "scope": "instance", "category": "Spatial" },
          "apply": { "mode": "safe_point", "requires_graph_update": true }
        }
      ]
    },

    {
      "type_id": "fx.virtual_bass",
      "category": "playback/fx",
      "abi_version": 3,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "static_schema": { "preset_ref": true, "fields": [{ "key": "harmonics_mode", "type": "enum", "enum": ["off", "mild", "strong"], "default": "mild" }] },
      "runtime_params": [
        {
          "param_id": "enable",
          "param_name": "VBass Switch",
          "value_type": "bool",
          "default": true,
          "tlv": { "type": 18432, "length_bytes": 1 },
          "kcontrol": { "kind": "switch", "scope": "instance", "category": "FX" },
          "apply": { "mode": "next_frame" }
        },
        {
          "param_id": "gain_db",
          "param_name": "VBass Gain",
          "value_type": "int16",
          "unit": "dB",
          "range": { "min": -12, "max": 12, "step": 1 },
          "default": 0,
          "tlv": { "type": 18433, "length_bytes": 2, "encoding": { "qfmt": "q8.8" } },
          "kcontrol": { "kind": "value", "scope": "instance", "category": "FX", "tlv_scale": { "min": -12, "max": 12, "step": 1 } },
          "apply": { "mode": "next_frame" }
        }
      ]
    },

    {
      "type_id": "fx.surround_decoder",
      "category": "playback/spatial",
      "abi_version": 3,
      "io": { "in_ports": [{ "name": "in", "max_ch": 2 }], "out_ports": [{ "name": "out", "max_ch": 8 }] },
      "runtime_params": [
        {
          "param_id": "mode",
          "param_name": "Surround Mode",
          "value_type": "enum",
          "enum": ["off", "movie", "music"],
          "default": "movie",
          "tlv": { "type": 18688, "length_bytes": 1 },
          "kcontrol": { "kind": "enum", "scope": "instance", "category": "Spatial" },
          "apply": { "mode": "safe_point", "requires_graph_update": true }
        }
      ]
    },

    {
      "type_id": "fx.virtualizer",
      "category": "playback/spatial",
      "abi_version": 3,
      "io": { "in_ports": [{ "name": "in", "max_ch": 8 }], "out_ports": [{ "name": "out", "max_ch": 8 }] },
      "runtime_params": [
        {
          "param_id": "target",
          "param_name": "Virtualizer Target",
          "value_type": "enum",
          "enum": ["speaker", "headphone"],
          "default": "speaker",
          "tlv": { "type": 18944, "length_bytes": 1 },
          "kcontrol": { "kind": "enum", "scope": "instance", "category": "Spatial" },
          "apply": { "mode": "safe_point", "requires_graph_update": true }
        },
        {
          "param_id": "strength",
          "param_name": "Virtualizer Strength",
          "value_type": "uint8",
          "range": { "min": 0, "max": 100, "step": 1 },
          "default": 50,
          "tlv": { "type": 18945, "length_bytes": 1 },
          "kcontrol": { "kind": "value", "scope": "instance", "category": "Spatial" },
          "apply": { "mode": "next_frame" }
        }
      ]
    },

    {
      "type_id": "fx.loudness",
      "category": "playback/fx",
      "abi_version": 2,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "runtime_params": [
        {
          "param_id": "enable",
          "param_name": "Loudness Switch",
          "value_type": "bool",
          "default": false,
          "tlv": { "type": 19200, "length_bytes": 1 },
          "kcontrol": { "kind": "switch", "scope": "instance", "category": "FX" },
          "apply": { "mode": "next_frame" }
        }
      ]
    },

    {
      "type_id": "protect.speaker",
      "category": "playback/protect",
      "abi_version": 2,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "runtime_params": [
        {
          "param_id": "enable",
          "param_name": "SPK Protect Switch",
          "value_type": "bool",
          "default": true,
          "tlv": { "type": 19456, "length_bytes": 1 },
          "kcontrol": { "kind": "switch", "scope": "instance", "category": "Protection" },
          "apply": { "mode": "next_frame" }
        },
        {
          "param_id": "limiter_threshold_db",
          "param_name": "Limiter Thresh",
          "value_type": "int16",
          "unit": "dB",
          "range": { "min": -30, "max": 0, "step": 1 },
          "default": -6,
          "tlv": { "type": 19457, "length_bytes": 2, "encoding": { "qfmt": "q8.8" } },
          "kcontrol": { "kind": "value", "scope": "instance", "category": "Protection", "tlv_scale": { "min": -30, "max": 0, "step": 1 } },
          "apply": { "mode": "next_frame" }
        }
      ]
    },

    {
      "type_id": "rate.src",
      "category": "common/rate",
      "abi_version": 2,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
