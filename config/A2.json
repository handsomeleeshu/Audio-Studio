      "io": { "in_ports": [{ "name": "mic", "max_ch": 4 }, { "name": "ref", "max_ch": 2 }], "out_ports": [{ "name": "anti", "max_ch": 2 }] },
      "runtime_params": [
        {
          "param_id": "enable",
          "param_name": "ANC Switch",
