    },

    {
      "type_id": "service.asrc",
      "category": "service/core3",
      "abi_version": 1,
      "io": { "in_ports": [{ "name": "in", "max_ch": 16 }], "out_ports": [{ "name": "out", "max_ch": 16 }] },
      "runtime_params": [
        {
          "param_id": "enable",
          "param_name": "ASRC Switch",
          "value_type": "bool",
          "default": true,
          "tlv": { "type": 20480, "length_bytes": 1 },
          "kcontrol": { "kind": "switch", "scope": "instance", "category": "Rate" },
          "apply": { "mode": "safe_point" }
        }
      ],
      "service_binding": { "preferred_core": "core3" }
