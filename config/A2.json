        {
          "param_id": "echo_suppress_db",
          "param_name": "Echo Suppress",
          "value_type": "int16",
          "unit": "dB",
          "range": { "min": -60, "max": 0, "step": 1 },
          "default": -20,
          "tlv": { "type": 24577, "length_bytes": 2, "encoding": { "qfmt": "q8.8" } },
          "kcontrol": { "kind": "value", "scope": "instance", "category": "VAVS", "tlv_scale": { "min": -60, "max": 0, "step": 1 } },
          "apply": { "mode": "next_frame" }
        }
      ]
    },

    {
      "type_id": "vavs.ns",
      "category": "capture/vavs",
      "abi_version": 3,
      "io": { "in_ports": [{ "name": "in", "max_ch": 8 }], "out_ports": [{ "name": "out", "max_ch": 8 }] },
      "runtime_params": [
        {
