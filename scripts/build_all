#!/usr/bin/env bash
# SPDX-License-Identifier: BSD-3-Clause
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

platform="simulator"
arch="host"
target_os="auto"
toolchain="default"
build_type="Release"
defconfig=""
cmake_generator=""
configure_only=0
clean=0

usage() {
  cat <<'USAGE'
Usage: scripts/build_all [options]

SOF-style top-level build entry for Audio Studio.

The script selects a platform/arch/toolchain tuple, resolves a defconfig from
src/arch/<arch>/configs, lets CMake run the Kconfig flow, then builds the
selected targets. Kconfig remains the source of truth; CMake consumes the
resulting generated/.config and generated/include/generated/autoconf.h.

Options:
  -p, --platform <simulator|a2>      Platform profile. Default: simulator
  -a, --arch <host>                 Build architecture. Default: host
  -o, --target-os <linux|macos|auto> Target OS hint. Default: auto
  -t, --toolchain <default|gcc|clang> Toolchain hint. Default: default
  -b, --build-type <type>           CMake build type. Default: Release
  -d, --defconfig <path|name>       Initial Kconfig defconfig
  -g, --generator <name>            CMake generator, for example Ninja
  -c, --clean                       Remove the selected build directory first
      --configure-only              Configure but do not build
  -h, --help                        Show this help

Examples:
  scripts/build_all -p simulator -o linux -t gcc
  scripts/build_all -p a2 -a host -d a2_linux_defconfig
  scripts/build_all --clean --platform simulator --generator Ninja
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--platform)
      platform="${2:?missing value for $1}"; shift 2 ;;
    -a|--arch)
      arch="${2:?missing value for $1}"; shift 2 ;;
    -o|--target-os)
      target_os="${2:?missing value for $1}"; shift 2 ;;
    -t|--toolchain)
      toolchain="${2:?missing value for $1}"; shift 2 ;;
    -b|--build-type)
      build_type="${2:?missing value for $1}"; shift 2 ;;
    -d|--defconfig|--init-config)
      defconfig="${2:?missing value for $1}"; shift 2 ;;
    -g|--generator)
      cmake_generator="${2:?missing value for $1}"; shift 2 ;;
    -c|--clean)
      clean=1; shift ;;
    --configure-only)
      configure_only=1; shift ;;
    -h|--help)
      usage; exit 0 ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2 ;;
  esac
done

if [[ "$target_os" == "auto" ]]; then
  case "$(uname -s)" in
    Linux*) target_os="linux" ;;
    Darwin*) target_os="macos" ;;
    *) target_os="unknown" ;;
  esac
fi

case "$arch" in
  host)
    ;;
  *)
    echo "Unsupported M0 arch: $arch" >&2
    echo "M0 supports host builds. Additional arch toolchains will be added later." >&2
    exit 2 ;;
esac

case "$platform" in
  simulator|a2)
    ;;
  *)
    echo "Unsupported platform: $platform" >&2
    exit 2 ;;
esac

case "$toolchain" in
  default|gcc|clang)
    ;;
  *)
    echo "Unsupported toolchain hint: $toolchain" >&2
    exit 2 ;;
esac

if ! python3 - <<'PY'
import importlib.util
raise SystemExit(0 if importlib.util.find_spec("kconfiglib") else 1)
PY
then
  cat >&2 <<'EOF'
Missing Python module: kconfiglib

Audio Studio now uses the same Kconfiglib-based flow as SOF helper scripts.
Install it before configuring, for example:

  python3 -m pip install --user kconfiglib

EOF
  exit 1
fi

resolve_defconfig() {
  local requested="$1"

  if [[ -n "$requested" ]]; then
    if [[ "$requested" == /* && -f "$requested" ]]; then
      printf '%s\n' "$requested"
      return 0
    fi
    if [[ -f "$ROOT/$requested" ]]; then
      printf '%s\n' "$ROOT/$requested"
      return 0
    fi
    if [[ -f "$ROOT/src/arch/$arch/configs/$requested" ]]; then
      printf '%s\n' "$ROOT/src/arch/$arch/configs/$requested"
      return 0
    fi
  fi

  local candidates=(
    "$ROOT/src/arch/$arch/configs/${platform}_${target_os}_defconfig"
    "$ROOT/src/arch/$arch/configs/${platform}_defconfig"
    "$ROOT/src/arch/$arch/configs/simulator_linux_defconfig"
  )

  local candidate
  for candidate in "${candidates[@]}"; do
    if [[ -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

if ! defconfig_path="$(resolve_defconfig "$defconfig")"; then
  echo "Unable to resolve defconfig for arch=$arch platform=$platform target_os=$target_os" >&2
  exit 1
fi

build_type_lc="$(printf '%s' "$build_type" | tr '[:upper:]' '[:lower:]')"
build_dir="$ROOT/build/${arch}-${platform}-${target_os}-${toolchain}-${build_type_lc}"

if [[ "$clean" -eq 1 ]]; then
  rm -rf "$build_dir"
fi

mkdir -p "$build_dir"

# Pass INIT_CONFIG relative to the source tree when possible. This mirrors SOF's
# CMake Kconfig helper which searches src/arch/<arch>/configs and then freezes
# the active config as generated/.config inside the build directory.
init_config="$defconfig_path"
if [[ "$defconfig_path" == "$ROOT"/* ]]; then
  init_config="${defconfig_path#"$ROOT"/}"
fi

cmake_args=(
  -S "$ROOT"
  -B "$build_dir"
  -DARCH="$arch"
  -DINIT_CONFIG="$init_config"
  -DAUDIO_STUDIO_PLATFORM="$platform"
  -DAUDIO_STUDIO_TARGET_OS="$target_os"
  -DAUDIO_STUDIO_TOOLCHAIN="$toolchain"
  -DCMAKE_BUILD_TYPE="$build_type"
)

if [[ -n "$cmake_generator" ]]; then
  cmake_args+=( -G "$cmake_generator" )
fi

case "$toolchain" in
  default)
    ;;
  gcc)
    cmake_args+=( -DCMAKE_C_COMPILER=gcc -DCMAKE_CXX_COMPILER=g++ ) ;;
  clang)
    cmake_args+=( -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ ) ;;
esac

cmake "${cmake_args[@]}"

if [[ "$configure_only" -eq 0 ]]; then
  cmake --build "$build_dir" -j"$(getconf _NPROCESSORS_ONLN 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4)"
fi

cat <<EOF

Audio Studio build completed.
  build_dir:     $build_dir
  arch:          $arch
  platform:      $platform
  target_os:     $target_os
  toolchain:     $toolchain
  init_config:   $init_config
  active config: $build_dir/generated/.config
  header:        $build_dir/generated/include/generated/autoconf.h

Useful Kconfig targets inside build dir:
  cmake --build $build_dir --target menuconfig
  cmake --build $build_dir --target olddefconfig
  cmake --build $build_dir --target savedefconfig
EOF
